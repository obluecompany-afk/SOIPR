{%- comment -%}
  Customer đổi mật khẩu — yêu cầu đã đăng nhập
  Dùng {% form 'customer' %} với type=password (Haravan convention)
{%- endcomment -%}

<section class="kb-auth">
  <h1 class="kb-section-title">ĐỔI MẬT KHẨU</h1>
  <p style="color:#888;margin-bottom:24px;font-size:13px;">
    Đổi mật khẩu cho tài khoản <strong>{{ customer.email }}</strong>
  </p>

  {% form 'customer' %}
    {% if form.errors %}
      <div class="kb-form-errors">{{ form.errors | default_errors }}</div>
    {% endif %}
    {% if form.posted_successfully? %}
      <p style="color:#7a9;background:#f0fff4;padding:12px;border-radius:6px;font-size:13px;">
        ✓ Đã đổi mật khẩu thành công.
      </p>
    {% endif %}

    <input type="hidden" name="form_type" value="customer" />

    <label class="kb-form-label">Mật khẩu hiện tại</label>
    <input type="password" name="customer[current_password]" required class="kb-form-input" />

    <label class="kb-form-label">Mật khẩu mới</label>
    <input type="password" name="customer[password]" required class="kb-form-input" minlength="8" />
    <p style="font-size:11px;color:#888;margin-top:4px;">Tối thiểu 8 ký tự.</p>

    <label class="kb-form-label">Xác nhận mật khẩu mới</label>
    <input type="password" name="customer[password_confirmation]" required class="kb-form-input" minlength="8" />

    <div style="display:flex;gap:12px;margin-top:20px;">
      <a href="/account" class="kb-btn-secondary" style="flex:1;text-align:center;">HUỶ</a>
      <button type="submit" class="kb-btn-primary" style="flex:2;">ĐỔI MẬT KHẨU</button>
    </div>
  {% endform %}
</section>
