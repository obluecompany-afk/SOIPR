{%- comment -%}
  Customer orders list
{%- endcomment -%}

<section class="kb-account">
  <header class="kb-account__header">
    <h1 class="kb-section-title">ĐƠN HÀNG CỦA TÔI</h1>
    <a href="/account" class="kb-link-muted">← Quay lại</a>
  </header>

  {% if customer.orders.size > 0 %}
    <table class="kb-orders-table">
      <thead>
        <tr><th>Mã đơn</th><th>Ngày</th><th>Tổng tiền</th><th>Thanh toán</th><th>Vận chuyển</th><th></th></tr>
      </thead>
      <tbody>
        {% paginate customer.orders by 20 %}
          {% for order in customer.orders %}
            <tr>
              <td><a href="{{ order.customer_url }}">#{{ order.name }}</a></td>
              <td>{{ order.created_at | date: '%d/%m/%Y' }}</td>
              <td>{{ order.total_price | money }}</td>
              <td>{{ order.financial_status_label }}</td>
              <td>{{ order.fulfillment_status_label }}</td>
              <td><a href="{{ order.customer_url }}" class="kb-link-muted">Xem →</a></td>
            </tr>
          {% endfor %}
        {% endpaginate %}
      </tbody>
    </table>
  {% else %}
    <p style="text-align:center;color:#888;padding:60px 0;">
      Bạn chưa có đơn hàng nào.
      <a href="/collections/all" class="kb-link-muted">Mua sắm →</a>
    </p>
  {% endif %}
</section>
