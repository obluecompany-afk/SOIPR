{%- comment -%}
  Customer register — dùng {% form 'create_customer' %}
{%- endcomment -%}

<section class="kb-auth">
  <h1 class="kb-section-title">ĐĂNG KÝ</h1>

  {% form 'create_customer' %}
    {% if form.errors %}
      <div class="kb-form-errors">{{ form.errors | default_errors }}</div>
    {% endif %}

    <div class="kb-field-row">
      <div>
        <label class="kb-form-label">Họ</label>
        <input type="text" name="customer[first_name]" required class="kb-form-input" />
      </div>
      <div>
        <label class="kb-form-label">Tên</label>
        <input type="text" name="customer[last_name]" required class="kb-form-input" />
      </div>
    </div>

    <label class="kb-form-label">Email</label>
    <input type="email" name="customer[email]" required class="kb-form-input" />

    <label class="kb-form-label">Mật khẩu</label>
    <input type="password" name="customer[password]" required class="kb-form-input" minlength="8" />
    <p style="font-size:11px;color:#888;margin-top:4px;">Tối thiểu 8 ký tự.</p>

    <label style="display:flex;align-items:center;gap:8px;margin-top:16px;font-size:13px;">
      <input type="checkbox" name="customer[accepts_marketing]" value="1" />
      Đăng ký nhận tin khuyến mãi
    </label>

    <button type="submit" class="kb-btn-primary kb-btn-block" style="margin-top:20px;">
      ĐĂNG KÝ
    </button>

    <p style="text-align:center;margin-top:16px;font-size:13px;">
      Đã có tài khoản? <a href="/account/login" class="kb-link-muted">Đăng nhập →</a>
    </p>
  {% endform %}
</section>
