{%- comment -%}
  Reset password — link gửi qua email khi quên password
{%- endcomment -%}

<section class="kb-auth">
  <h1 class="kb-section-title">ĐẶT LẠI MẬT KHẨU</h1>
  <p style="color:#888;margin-bottom:20px;font-size:13px;">
    Nhập mật khẩu mới cho tài khoản của bạn.
  </p>

  {% form 'reset_customer_password' %}
    {% if form.errors %}
      <div class="kb-form-errors">{{ form.errors | default_errors }}</div>
    {% endif %}

    <label class="kb-form-label">Mật khẩu mới</label>
    <input type="password" name="customer[password]" required class="kb-form-input" minlength="8" />

    <label class="kb-form-label">Xác nhận mật khẩu</label>
    <input type="password" name="customer[password_confirmation]" required class="kb-form-input" minlength="8" />

    <button type="submit" class="kb-btn-primary kb-btn-block" style="margin-top:16px;">
      ĐẶT LẠI MẬT KHẨU
    </button>
  {% endform %}
</section>
